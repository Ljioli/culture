@import "../../../../../style/public/comm_box_list.wxss";
@import "../../../style/skin.wxss";

page {
	background: #f4f7fb;
}

.guide-page {
	min-height: 100vh;
	padding: 24rpx 24rpx 150rpx;
	box-sizing: border-box;
	background: #f4f7fb;
}

.guide-shell {
	display: flex;
	flex-direction: column;
	gap: 18rpx;
}

.guide-top {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 6rpx 4rpx;
}

.guide-title {
	font-size: 42rpx;
	font-weight: 700;
	color: #202530;
}

.guide-status {
	padding: 10rpx 20rpx;
	border-radius: 999rpx;
	background: rgba(255, 255, 255, 0.72);
	color: #8e8f9b;
	font-size: 22rpx;
}

.guide-status.ok {
	color: #2b9a68;
	background: rgba(233, 250, 240, 0.92);
}

.assistant-card {
	display: flex;
	align-items: center;
	gap: 18rpx;
	padding: 24rpx;
	border-radius: 28rpx;
	background: linear-gradient(120deg, #eef3ff 0%, #ecf8f5 100%);
}

.assistant-avatar {
	width: 92rpx;
	height: 92rpx;
	border-radius: 50%;
	background: linear-gradient(135deg, #7b89ff, #47c1ff);
	color: #fff;
	font-size: 30rpx;
	font-weight: 700;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
}

.assistant-copy {
	flex: 1;
}

.assistant-heading {
	font-size: 34rpx;
	font-weight: 700;
	color: #1f2b4d;
	margin-bottom: 8rpx;
}

.assistant-sub {
	font-size: 24rpx;
	line-height: 1.6;
	color: #5f667a;
}

.suggest-card {
	padding: 18rpx 18rpx 8rpx;
	border-radius: 28rpx;
	background: rgba(255, 255, 255, 0.94);
}

.suggest-head {
	padding: 8rpx 10rpx 14rpx;
}

.suggest-title {
	font-size: 30rpx;
	font-weight: 700;
	color: #4d78df;
}

.suggest-list {
	display: flex;
	flex-direction: column;
	gap: 14rpx;
}

.suggest-item {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 22rpx 24rpx;
	border-radius: 22rpx;
	background: #fff;
}

.suggest-text {
	flex: 1;
	font-size: 28rpx;
	line-height: 1.5;
	color: #262b35;
}

.suggest-arrow {
	margin-left: 18rpx;
	font-size: 34rpx;
	color: #b4bfd0;
}

.chat-list {
	flex: 1;
	min-height: 260rpx;
	height: auto;
	padding: 10rpx 2rpx 10rpx;
	box-sizing: border-box;
}

.chat-row {
	display: flex;
	margin-bottom: 18rpx;
}

.chat-row.user {
	justify-content: flex-end;
}

.chat-row.assistant {
	justify-content: flex-start;
}

.chat-bubble {
	max-width: 84%;
	padding: 22rpx 24rpx;
	border-radius: 26rpx;
}

.chat-bubble.user {
	background: linear-gradient(135deg, #4b8fff, #3a73ea);
	color: #fff;
	border-bottom-right-radius: 10rpx;
}

.chat-bubble.assistant {
	background: rgba(255, 255, 255, 0.96);
	color: #1f2430;
	border-bottom-left-radius: 10rpx;
}

.chat-bubble.error {
	background: #fff2ee;
	color: #9a432d;
}

.chat-content {
	font-size: 28rpx;
	line-height: 1.72;
	white-space: pre-wrap;
	word-break: break-word;
}

.chat-sources {
	margin-top: 16rpx;
	padding-top: 16rpx;
	border-top: 1rpx solid rgba(0, 0, 0, 0.08);
}

.chat-sources-title {
	font-size: 22rpx;
	color: #6d7282;
	margin-bottom: 6rpx;
}

.chat-source-item {
	font-size: 22rpx;
	line-height: 1.55;
	color: #7b8090;
}

.composer-wrap {
	position: fixed;
	left: 0;
	right: 0;
	bottom: 0;
	z-index: 20;
	padding: 14rpx 24rpx 0;
	background: #f4f7fb;
	box-sizing: border-box;
}

.composer {
	display: flex;
	align-items: center;
	gap: 14rpx;
	padding: 16rpx;
	border-radius: 26rpx 26rpx 0 0;
	background: rgba(255, 255, 255, 0.98);
	box-shadow: 0 12rpx 34rpx rgba(37, 62, 96, 0.08);
}

.composer-input {
	flex: 1;
	height: 82rpx;
	padding: 0 22rpx;
	border-radius: 18rpx;
	background: #f0f4fa;
	font-size: 26rpx;
}

.composer-btn {
	min-width: 126rpx;
	height: 82rpx;
	padding: 0 24rpx;
	border-radius: 20rpx;
	background: linear-gradient(135deg, #4b8fff, #3a73ea);
	color: #fff;
	font-size: 28rpx;
	font-weight: 700;
	display: flex;
	align-items: center;
	justify-content: center;
}
