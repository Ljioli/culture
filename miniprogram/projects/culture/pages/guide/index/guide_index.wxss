@import "../../../../../style/public/comm_box_list.wxss";
@import "../../../style/skin.wxss";

page {
	background: #f7f1ea;
}

.main {
	padding: 24rpx 24rpx 220rpx;
	box-sizing: border-box;
}

.hero,
.quick,
.composer,
.bubble {
	background: #fff;
	border-radius: 24rpx;
}

.hero {
	padding: 28rpx;
	margin-bottom: 20rpx;
}

.hero-title {
	font-size: 34rpx;
	font-weight: 700;
	color: #7b4c27;
	margin-bottom: 12rpx;
}

.hero-desc,
.hero-tip {
	font-size: 24rpx;
	line-height: 1.7;
	color: #6d6258;
}

.hero-tip {
	margin-top: 12rpx;
	color: #9b7b5c;
}

.quick {
	padding: 24rpx;
	margin-bottom: 20rpx;
}

.block-title {
	font-size: 28rpx;
	font-weight: 700;
	color: #2f2a24;
	margin-bottom: 18rpx;
}

.chips {
	display: flex;
	flex-wrap: wrap;
	gap: 16rpx;
}

.chip {
	padding: 14rpx 20rpx;
	border-radius: 999rpx;
	background: #f5e8dc;
	color: #8a5a33;
	font-size: 24rpx;
}

.chat-list {
	height: calc(100vh - 560rpx);
}

.message {
	display: flex;
	margin-bottom: 20rpx;
}

.message.user {
	justify-content: flex-end;
}

.message.assistant {
	justify-content: flex-start;
}

.bubble {
	max-width: 86%;
	padding: 22rpx 24rpx;
}

.message.user .bubble {
	background: linear-gradient(135deg, #b77440, #8e5328);
	color: #fff;
}

.message.assistant .bubble {
	background: #fff;
	color: #3b332d;
}

.message.error .bubble {
	background: #fff3ef;
	color: #9a4027;
}

.role {
	font-size: 22rpx;
	font-weight: 700;
	margin-bottom: 10rpx;
	opacity: 0.8;
}

.content {
	font-size: 28rpx;
	line-height: 1.7;
	white-space: pre-wrap;
}

.sources {
	margin-top: 16rpx;
	padding-top: 16rpx;
	border-top: 1rpx solid rgba(0, 0, 0, 0.08);
}

.message.user .sources {
	border-top-color: rgba(255, 255, 255, 0.25);
}

.sources-title {
	font-size: 22rpx;
	margin-bottom: 8rpx;
	opacity: 0.8;
}

.source-item {
	font-size: 22rpx;
	line-height: 1.6;
	opacity: 0.95;
}

.composer {
	position: fixed;
	left: 24rpx;
	right: 24rpx;
	bottom: calc(24rpx + env(safe-area-inset-bottom));
	display: flex;
	align-items: center;
	gap: 16rpx;
	padding: 18rpx;
	box-sizing: border-box;
}

.input {
	flex: 1;
	height: 80rpx;
	padding: 0 22rpx;
	background: #f6f3ef;
	border-radius: 18rpx;
	font-size: 26rpx;
}

.send-btn {
	width: 132rpx;
	height: 80rpx;
	border-radius: 18rpx;
	background: linear-gradient(135deg, #b77440, #8e5328);
	color: #fff;
	font-size: 28rpx;
	font-weight: 700;
	display: flex;
	align-items: center;
	justify-content: center;
}
