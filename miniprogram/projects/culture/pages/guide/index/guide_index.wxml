<view class="guide-page">
	<view class="guide-shell">
		<view class="guide-top">
			<view class="guide-title">AI对话</view>
			<view class="guide-status {{serviceStatus === '已连接' ? 'ok' : ''}}">{{serviceStatus}}</view>
		</view>

		<view class="assistant-card shadow-project">
			<view class="assistant-avatar">AI</view>
			<view class="assistant-copy">
				<view class="assistant-heading">Hi，我是小助手，很高兴为您服务</view>
				<view class="assistant-sub">可以直接问我景区介绍、活动安排、开放时间、门票、交通、停车、酒店和餐饮。</view>
			</view>
		</view>

		<view class="suggest-card shadow-project">
			<view class="suggest-head">
				<view class="suggest-title">猜你想问</view>
			</view>
			<view class="suggest-list">
				<view class="suggest-item" wx:for="{{quickQuestions}}" wx:key="index" data-question="{{item}}" bindtap="useQuickQuestion">
					<text class="suggest-text">{{item}}</text>
					<text class="suggest-arrow">›</text>
				</view>
			</view>
		</view>

		<scroll-view class="chat-list" scroll-y="true" scroll-with-animation="true" scroll-into-view="{{toView}}">
			<view wx:for="{{messages}}" wx:key="id" id="{{item.id}}" class="chat-row {{item.role}}">
				<view class="chat-bubble {{item.role}} {{item.isError ? 'error' : ''}}">
					<view class="chat-content">{{item.content}}</view>
					<view class="chat-sources" wx:if="{{item.sources && item.sources.length}}">
						<view class="chat-sources-title">参考来源</view>
						<view class="chat-source-item" wx:for="{{item.sources}}" wx:key="index">{{item}}</view>
					</view>
				</view>
			</view>

			<view wx:if="{{loading}}" class="chat-row assistant">
				<view class="chat-bubble assistant">
					<view class="chat-content">正在整理答案，请稍候...</view>
				</view>
			</view>
		</scroll-view>

		<view class="composer-wrap">
			<view class="composer shadow-project">
				<input class="composer-input" maxlength="200" placeholder="{{placeholder}}" value="{{question}}" bindinput="bindInput" confirm-type="send" bindconfirm="sendQuestion" />
				<view class="composer-btn" bindtap="sendQuestion">发送</view>
			</view>
		</view>
	</view>
</view>
